{"root":{"data":{"id":"djvo6m47cn40","created":1783765743933,"text":"阴司","font-size":48,"font-weight":"bold"},"children":[{"data":{"id":"djvo7wqdtzs0","created":1783765845406,"text":"地藏王","font-size":24,"font-weight":"bold"},"children":[{"data":{"id":"djvo81o1oa80","created":1783765856149,"text":"1秦广王:专司人间寿夭生死，统管吉凶。善人直接接引，恶人交予其他各殿审判","layout_right_offset":{"x":32.99999901652336,"y":-297.9999911189081},"priority":null,"font-size":16},"children":[]},{"data":{"id":"djvo8ofcwbs0","created":1783765905689,"text":"2楚江王:掌管活大地狱（寒冰地狱），惩罚在阳间伤人肢体、奸盗杀生等罪","priority":null,"layout_right_offset":{"x":39.99999880790699,"y":-263.9999921321871},"font-size":16},"children":[]},{"data":{"id":"djvo8wymbcg0","created":1783765924268,"text":"3宋帝王掌管黑绳大地狱，惩罚阳间忤逆尊长、背信弃义、教唆兴讼等罪","priority":null,"layout_right_offset":{"x":40.99999877810467,"y":-249.99999254941974},"font-size":16},"children":[]},{"data":{"id":"djvo9ml3frs0","created":1783765980048,"text":"4五官王","layout_right_offset":{"x":48.999998539685976,"y":-243.99999272823356},"priority":null,"font-size":16},"children":[]},{"data":{"id":"djvoaatx5k80","created":1783766032823,"text":"5阎罗王","layout_right_offset":{"x":49.99999850988388,"y":-245.9999926686288},"font-size":16},"children":[]},{"data":{"id":"djvoaicnji00","created":1783766049194,"text":"6卞城王","layout_right_offset":{"x":55.99999833106983,"y":-242.9999927580359}},"children":[]}]}]},"template":"default","theme":"wire","version":"1.4.43"}